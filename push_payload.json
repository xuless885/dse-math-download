{"files": [{"path": "index.html", "content": "<!DOCTYPE html>\n<html lang=\"zh-HK\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>下载你的 DSE 数学资料</title>\n\n  <!--\n  ╔══════════════════════════════════════╗\n  ║  DSE 数学笔记 · Stripe 验证下载站   ║\n  ║  付款后 Stripe 自动跳转到此页面     ║\n  ║  携带 ?session_id=cs_xxx 参数       ║\n  ╚══════════════════════════════════════╝\n  -->\n\n  <style>\n    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }\n\n    :root {\n      --bg: #faf9f7;\n      --card: #ffffff;\n      --text: #2d2a26;\n      --text-light: #6b6560;\n      --accent: #3b82f6;\n      --accent-hover: #2563eb;\n      --border: #e8e4df;\n      --success: #16a34a;\n      --success-bg: #f0fdf4;\n      --error: #dc2626;\n      --error-bg: #fef2f2;\n      --shadow: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);\n      --shadow-lg: 0 4px 16px rgba(0,0,0,0.06), 0 1px 4px rgba(0,0,0,0.04);\n    }\n\n    body {\n      font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", \"PingFang SC\", \"PingFang HK\", \"Microsoft YaHei\", sans-serif;\n      background: var(--bg);\n      color: var(--text);\n      line-height: 1.6;\n      min-height: 100vh;\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n    }\n\n    /* ── Loading / Error / Empty states ── */\n    .state-container {\n      display: none;\n      width: 100%;\n      max-width: 640px;\n      margin: 80px auto 0;\n      padding: 0 20px;\n    }\n    .state-container.active { display: block; }\n\n    .state-card {\n      background: var(--card);\n      border-radius: 16px;\n      padding: 48px 32px;\n      text-align: center;\n      box-shadow: var(--shadow-lg);\n      border: 1px solid var(--border);\n    }\n\n    .state-icon {\n      font-size: 56px;\n      margin-bottom: 16px;\n      display: block;\n    }\n    .state-title {\n      font-size: 22px;\n      font-weight: 700;\n      margin-bottom: 8px;\n      color: var(--text);\n    }\n    .state-desc {\n      font-size: 15px;\n      color: var(--text-light);\n      line-height: 1.7;\n    }\n\n    /* Spinner */\n    .spinner {\n      display: inline-block;\n      width: 40px; height: 40px;\n      border: 3px solid var(--border);\n      border-top-color: var(--accent);\n      border-radius: 50%;\n      animation: spin 0.8s linear infinite;\n      margin-bottom: 20px;\n    }\n    @keyframes spin { to { transform: rotate(360deg); } }\n\n    /* ── Success Download Page ── */\n    .success-container {\n      display: none;\n      width: 100%;\n      max-width: 680px;\n      margin: 0 auto;\n      padding: 20px;\n    }\n    .success-container.active { display: block; }\n\n    .success-header {\n      text-align: center;\n      padding: 40px 20px 32px;\n    }\n    .success-header .checkmark {\n      display: inline-flex;\n      align-items: center;\n      justify-content: center;\n      width: 64px; height: 64px;\n      background: var(--success-bg);\n      border-radius: 50%;\n      font-size: 32px;\n      margin-bottom: 16px;\n    }\n    .success-header h1 {\n      font-size: 26px;\n      font-weight: 700;\n      margin-bottom: 6px;\n    }\n    .success-header .order-id {\n      font-size: 13px;\n      color: var(--text-light);\n    }\n\n    /* Download cards */\n    .download-list {\n      display: flex;\n      flex-direction: column;\n      gap: 12px;\n    }\n\n    .download-card {\n      background: var(--card);\n      border-radius: 14px;\n      padding: 20px 24px;\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      box-shadow: var(--shadow);\n      border: 1px solid var(--border);\n      text-decoration: none;\n      color: inherit;\n      transition: box-shadow 0.2s, border-color 0.2s;\n      cursor: pointer;\n    }\n    .download-card:hover {\n      box-shadow: var(--shadow-lg);\n      border-color: var(--accent);\n    }\n\n    .download-card .info {\n      display: flex;\n      align-items: center;\n      gap: 14px;\n      flex: 1;\n      min-width: 0;\n    }\n    .download-card .file-icon {\n      font-size: 36px;\n      flex-shrink: 0;\n    }\n    .download-card .file-name {\n      font-size: 16px;\n      font-weight: 600;\n      color: var(--text);\n      margin-bottom: 2px;\n    }\n    .download-card .file-meta {\n      font-size: 13px;\n      color: var(--text-light);\n    }\n\n    .download-card .dl-btn {\n      display: inline-flex;\n      align-items: center;\n      gap: 6px;\n      padding: 10px 20px;\n      background: var(--accent);\n      color: #fff;\n      border-radius: 10px;\n      font-size: 14px;\n      font-weight: 600;\n      white-space: nowrap;\n      border: none;\n      cursor: pointer;\n      transition: background 0.2s;\n      flex-shrink: 0;\n    }\n    .download-card .dl-btn:hover { background: var(--accent-hover); }\n\n    /* Info box */\n    .info-box {\n      background: #f0f7ff;\n      border: 1px solid #bfdbfe;\n      border-radius: 12px;\n      padding: 16px 20px;\n      margin-top: 20px;\n      font-size: 14px;\n      color: #1e40af;\n      line-height: 1.6;\n    }\n    .info-box .info-title {\n      font-weight: 600;\n      margin-bottom: 4px;\n    }\n\n    /* ── Mobile ── */\n    @media (max-width: 600px) {\n      .state-card { padding: 36px 20px; }\n      .success-header { padding: 28px 16px 24px; }\n      .success-header h1 { font-size: 22px; }\n      .download-card { flex-direction: column; align-items: flex-start; gap: 14px; }\n      .download-card .dl-btn { width: 100%; text-align: center; justify-content: center; }\n    }\n  </style>\n</head>\n<body>\n\n  <!-- ═══════════════ State: Verifying ═══════════════ -->\n  <div id=\"state-verifying\" class=\"state-container active\">\n    <div class=\"state-card\">\n      <div class=\"spinner\"></div>\n      <div class=\"state-title\">正在验证你的订单…</div>\n      <div class=\"state-desc\">请稍候，这只需要几秒钟</div>\n    </div>\n  </div>\n\n  <!-- ═══════════════ State: Invalid / No Session ═══════════════ -->\n  <div id=\"state-invalid\" class=\"state-container\">\n    <div class=\"state-card\">\n      <span class=\"state-icon\">🔒</span>\n      <div class=\"state-title\">未找到有效订单</div>\n      <div class=\"state-desc\">\n        此页面仅供已付款用户访问。<br>\n        如果你已完成付款，请通过小红书私信联系我，我会尽快处理。\n      </div>\n    </div>\n  </div>\n\n  <!-- ═══════════════ State: Error ═══════════════ -->\n  <div id=\"state-error\" class=\"state-container\">\n    <div class=\"state-card\">\n      <span class=\"state-icon\">⚠️</span>\n      <div class=\"state-title\">验证暂时失败</div>\n      <div class=\"state-desc\">\n        网络或服务暂时异常，请刷新页面重试。<br>\n        如果问题持续，请截图此页面并小红书私信我。\n        <span id=\"error-detail\" style=\"display:block;margin-top:12px;font-size:13px;color:#999;\"></span>\n      </div>\n    </div>\n  </div>\n\n  <!-- ═══════════════ State: Success ═══════════════ -->\n  <div id=\"state-success\" class=\"success-container\">\n    <div class=\"success-header\">\n      <div class=\"checkmark\">✅</div>\n      <h1>购买成功！</h1>\n      <div class=\"order-id\" id=\"order-id-display\"></div>\n    </div>\n\n    <div class=\"download-list\" id=\"download-list\"></div>\n\n    <div class=\"info-box\">\n      <div class=\"info-title\">📌 温馨提示</div>\n      链接长期有效，建议保存此页面或收藏。<br>\n      如果遇到下载问题，可以通过小红书私信联系我。<br>\n      PDF 文件已添加你的订单水印，请勿公开分享，感谢尊重创作成果 🙏\n    </div>\n  </div>\n\n  <!-- ═══════════════ Script ═══════════════ -->\n  <script src=\"./products.js\"></script>\n  <script type=\"module\">\n    import { loadStripe } from 'https://js.stripe.com/v3/';\n\n    (async function() {\n\n      function showState(id) {\n        document.querySelectorAll('.state-container, .success-container')\n          .forEach(el => el.classList.remove('active'));\n        const target = document.getElementById(id);\n        if (target) target.classList.add('active');\n      }\n\n      const params = new URLSearchParams(window.location.search);\n      const sessionId = params.get('session_id');\n      const urlProductId = params.get('product');\n\n      // 无 session_id → 未付款用户\n      if (!sessionId) {\n        showState('state-invalid');\n        return;\n      }\n\n      let matchedProducts = [];\n      let amount = 0;\n      let currency = 'hkd';\n\n      // 1. 如果 URL 带了 product 参数，直接精确匹配（最可靠）\n      if (urlProductId) {\n        matchedProducts = findProducts(0, 'hkd', urlProductId);\n      }\n\n      // 2. 否则尝试用 Stripe.js 验证订单金额和币种\n      if (matchedProducts.length === 0) {\n        try {\n          const STRIPE_KEY = 'pk_live_51Tk5raEgpGQiz7Fy17zqVDqn8CjTtVi6wUCupgD8I40e1KRRBIBhaJ42o41Lwld13YGFJgCU8FgHpOVux4NtjDmG00pQzvazee';\n          const stripe = await loadStripe(STRIPE_KEY);\n\n          if (stripe && stripe.checkout && stripe.checkout.sessions) {\n            const result = await stripe.checkout.sessions.retrieve(sessionId);\n            const session = result.checkoutSession || result;\n\n            if (session && session.payment_status === 'paid') {\n              amount = session.amount_total || 0;\n              currency = session.currency || 'hkd';\n              matchedProducts = findProducts(amount, currency, null);\n            }\n          }\n        } catch (err) {\n          console.warn('Stripe verification failed, falling back:', err);\n        }\n      }\n\n      // 3. 还是匹配不到 → 展示所有产品（兜底，确保用户能下载）\n      if (matchedProducts.length === 0) {\n        matchedProducts = PRODUCTS;\n      }\n\n      document.getElementById('order-id-display').textContent =\n        '订单编号: ' + sessionId.slice(0, 18) + '…' +\n        (amount ? ' · ' + (amount / 100).toFixed(2) + ' ' + currency.toUpperCase() : '');\n\n      const list = document.getElementById('download-list');\n\n      if (matchedProducts.length === 0) {\n        list.innerHTML = '<div class=\"state-card\"><div class=\"state-desc\">暂无产品，请联系老师。</div></div>';\n      } else {\n        list.innerHTML = matchedProducts.map((product, i) => {\n          const filesHtml = product.files.map(file => `\n            <a class=\"download-card\" href=\"${file.url}\" target=\"_blank\" rel=\"noopener\">\n              <div class=\"info\">\n                <span class=\"file-icon\">${file.icon || '📄'}</span>\n                <div>\n                  <div class=\"file-name\">${file.name}</div>\n                  <div class=\"file-meta\">${file.desc || ''} · ${file.format || 'PDF'}</div>\n                </div>\n              </div>\n              <span class=\"dl-btn\">⬇ 下载</span>\n            </a>\n          `).join('');\n\n          const label = matchedProducts.length > 1\n            ? `<div style=\"font-size:13px;color:var(--text-light);margin:${i === 0 ? '0' : '20px'} 0 8px 4px;\">📂 ${product.name}</div>`\n            : '';\n\n          return label + filesHtml;\n        }).join('');\n      }\n\n      showState('state-success');\n    })();\n  </script>\n\n</body>\n</html>\n"}, {"path": "products.js", "content": "/**\n * ╔════════════════════════════════════════════════════╗\n * ║  DSE 数学笔记 · 产品配置文件（多产品/多币种版）    ║\n * ║  支持：多产品、多币种（HKD / CNY）、多文件下载     ║\n * ╚════════════════════════════════════════════════════╝\n *\n * 配置规则：\n * 1. 每个产品必须有唯一 id\n * 2. priceRanges 里按币种配置价格区间（cents）\n * 3. files 里放该产品对应的所有下载文件\n *\n * 匹配逻辑：\n * 1. 优先用 URL 中的 product 参数精确匹配（如 ?product=cp01-answer）\n * 2. 其次用付款金额 + 币种自动匹配\n */\n\nconst PRODUCTS = [\n  {\n    id: \"26cp01-answer\",\n    name: \"2026 CP 01 参考答案\",\n    priceRanges: {\n      hkd: [2800, 4000],   // HKD 28.00 - 40.00\n      cny: [2400, 3500]    // RMB 24.00 - 35.00\n    },\n    files: [\n      {\n        name: \"DSE 模拟卷 2026 CP 01 · 参考答案\",\n        desc: \"逐题答案与评分标准\",\n        format: \"PDF\",\n        icon: \"📘\",\n        url: \"https://1drv.ms/b/c/9c6c235d3dfcdcf4/IQALvIDejv4xTJ8id3hhBovYAUFdGHcYBYZuo4zOwhXzMGA?e=jujn9i\"\n      }\n    ]\n  }\n  // ════════════════════════════════════════════════════════\n  // 添加新产品模板（复制后修改）：\n  // ════════════════════════════════════════════════════════\n  // {\n  //   id: \"cp02-answer\",\n  //   name: \"2026 CP 02 参考答案\",\n  //   priceRanges: {\n  //     hkd: [2800, 4000],\n  //     cny: [2400, 3500]\n  //   },\n  //   files: [\n  //     {\n  //       name: \"DSE 模拟卷 2026 CP 02 · 参考答案\",\n  //       desc: \"逐题答案与评分标准\",\n  //       format: \"PDF\",\n  //       icon: \"📘\",\n  //       url: \"你的 OneDrive / Google Drive 链接\"\n  //     }\n  //   ]\n  // },\n  // {\n  //   id: \"cp-bundle\",\n  //   name: \"2026 CP 01-06 全套答案\",\n  //   priceRanges: {\n  //     hkd: [12800, 18000],   // 套餐 HKD 128-180\n  //     cny: [10800, 15000]    // 套餐 RMB 108-150\n  //   },\n  //   files: [\n  //     { name: \"CP 01 参考答案\", ... },\n  //     { name: \"CP 02 参考答案\", ... },\n  //     // ...\n  //   ]\n  // },\n  // ════════════════════════════════════════════════════════\n];\n\n/**\n * 根据产品 ID、付款金额和币种匹配产品\n * @param {number} amount - 付款金额（cents）\n * @param {string} currency - 币种（hkd, cny 等）\n * @param {string} productId - 可选的 URL 参数 product\n * @returns {Array} 匹配到的产品列表\n */\nfunction findProducts(amount, currency, productId) {\n  // 1. 如果 URL 带了 product 参数，精确匹配\n  if (productId) {\n    const target = PRODUCTS.find(p => p.id === productId);\n    return target ? [target] : [];\n  }\n\n  // 2. 用金额 + 币种匹配\n  const ccy = (currency || 'hkd').toLowerCase();\n\n  return PRODUCTS.filter(product => {\n    const range = product.priceRanges[ccy];\n    if (!range) return false;\n    return amount >= range[0] && amount <= range[1];\n  });\n}\n"}], "message": "Update product id to 26cp01-answer", "owner": "xuless885", "repo": "dse-math-download", "branch": "main"}
